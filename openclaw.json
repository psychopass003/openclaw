{
  "agents": {
    "defaults": {
      "model": {
        "primary": "mistral/mistral-large-latest"
      }
    }
  },
  "models": {
    "providers": {
      "mistral": {
        "apiKey": "${MISTRAL_API_KEY}"
      }
    }
  },
  "plugins": {
    "allow": [
      "browser",
      "duckduckgo",
      "memory"
    ]
  },
  "browser": {
    "enabled": true,
    "defaultProfile": "openclaw",
    "headless": true,
    "extraArgs": [
      "--no-sandbox",
      "--disable-gpu",
      "--disable-software-rasterizer",
      "--disable-dev-shm-usage",
      "--js-flags=--max-old-space-size=2048",
      "--disable-extensions-except=/app/extensions/ubol,/app/extensions/videodownloader",
      "--load-extension=/app/extensions/ubol,/app/extensions/videodownloader"
    ],
    "profiles": {
      "openclaw": {
        "cdpPort": 18792,
        "color": "#0000ff"
      }
    }
  },
  "gateway": {
    "mode": "local",
    "port": 18789,
    "auth": {
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    }
  }
}