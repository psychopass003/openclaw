{
  "agents": {
    "defaults": {
      "model": {
        "primary": "mistral/mistral-large-latest"
      }
    }
  },
  "models": {
    "providers": {
      "mistral": {
        "apiKey": "${MISTRAL_API_KEY}"
      }
    }
  },
  "plugins": {
    "allow": [
      "browser",
      "duckduckgo"
    ]
  },
  "browser": {
    "enabled": true,
    "defaultProfile": "openclaw",
    "headless": true,
    "extraArgs": [
      "--no-sandbox",
      "--disable-gpu",
      "--disable-software-rasterizer",
      "--disable-dev-shm-usage",
      "--js-flags=--max-old-space-size=2048",
      "--disable-extensions-except=/app/extensions/ubol,/app/extensions/videodownloader",
      "--load-extension=/app/extensions/ubol,/app/extensions/videodownloader"
    ],
    "profiles": {
      "openclaw": {
        "cdpPort": 18792,
        "color": "#0000ff"
      }
    }
  },
  "gateway": {
    "mode": "local",
    "port": 18789,
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    // NOTE: as of this build, OpenClaw has an upstream bug (openclaw/openclaw#71103,
    // closed "not planned") that ignores this trustedProxies allowlist for WS-locality
    // classification whenever a request carries X-Forwarded-For/X-Real-IP/X-Forwarded-Proto,
    // regardless of whether the IP matches. nginx.conf works around this by simply not
    // sending those headers to the Gateway, so this setting is currently inert - kept here
    // so it starts working again automatically if/when OpenClaw fixes #71103 upstream.
    "trustedProxies": [
      "127.0.0.1"
    ],
    "controlUi": {
      "allowedOrigins": [
        "${SPACE_URL}",
        "https://johnwick003-openclaw.hf.space"
      ]
    }
  }
}